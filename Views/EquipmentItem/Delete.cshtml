@model Equipment_RentalNow.Data.Models.EquipmentItem

@{
    ViewData["Title"] = "Delete Equipment";
}

<h1>Delete Equipment</h1>

<div class="alert alert-danger">
    Сигурен ли си, че искаш да изтриеш това оборудване?
</div>

<div class="card mb-3">
    <div class="card-body">
        <h4>@Model.Name</h4>

        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Available Quantity:</strong> @Model.AvailableQuantity</p>
        <p><strong>Condition:</strong> @Model.Condition</p>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" style="max-width: 300px;" class="img-thumbnail" />
        }
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-controller="EquipmentItem" asp-action="Index" class="btn btn-secondary">
        Back
    </a>
</form>