@model Equipment_RentalNow.Data.Models.EquipmentItem

@{
    ViewData["Title"] = "Details";
}

<h1>Equipment Details</h1>

<div class="card">
    <div class="card-body">

        <h4>@Model.Name</h4>

        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Available Quantity:</strong> @Model.AvailableQuantity</p>
        <p><strong>Condition:</strong> @Model.Condition</p>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="img-thumbnail" style="max-width:300px;" />
        }

    </div>
</div>

<div class="mt-3">
    <a asp-controller="EquipmentItem" asp-action="Index" class="btn btn-secondary">
        Back
    </a>

    @if (User.IsInRole("Admin"))
    {
        <a asp-controller="EquipmentItem" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            Edit
        </a>
    }
</div>
